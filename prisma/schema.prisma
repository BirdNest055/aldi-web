// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// Schema mirrors the aldi-cli SQLite layout (SCD Type 2 timeline schema).
// Do NOT run `prisma migrate` — the DB is created by aldi-cli. We only use
// Prisma Client for typed reads here. Run `bun run db:push` once to sync
// the client without touching the data.
// ===========================================================================

model Publication {
  id              Int       @id
  slug            String    @unique
  groupId         Int       @map("group_id")
  title           String?
  originalTitle   String?   @map("original_title")
  language        String?
  canonicalUrl    String?   @map("canonical_url")
  pdfUrl          String?   @map("pdf_url")
  numPages        Int?      @map("num_pages")
  description     String?
  validFor        String?   @map("valid_for")
  validDates      String?   @map("valid_dates")
  validDateStart  String?   @map("valid_date_start")
  validDateEnd    String?   @map("valid_date_end")
  customerName    String?   @map("customer_name")
  cacheToken      String?   @map("cache_token")
  fetchedAt       String    @map("fetched_at")
  rawConfig       String?   @map("raw_config")

  spreads         Spread[]
  pages           Page[]
  hotspots        Hotspot[]
  offerings       ProductOffering[]

  @@map("publications")
}

model Product {
  id              Int       @id @default(autoincrement())
  productKey      String    @unique @map("product_key")
  canonicalTitle  String?   @map("canonical_title")
  canonicalType   String?   @map("canonical_type")
  firstSeenPubId  Int?      @map("first_seen_pub_id")
  lastSeenPubId   Int?      @map("last_seen_pub_id")
  firstSeenAt     String?   @map("first_seen_at")
  lastSeenAt      String?   @map("last_seen_at")

  offerings       ProductOffering[]
  titles          ProductTitle[]
  descriptions    ProductDescription[]
  brands          ProductBrand[]

  @@map("products")
}

model Spread {
  id              Int       @id @default(autoincrement())
  publicationId   Int       @map("publication_id")
  spreadIdx       Int       @map("spread_idx")
  pageRange       String    @map("page_range")
  numHotspots     Int       @default(0) @map("num_hotspots")

  publication     Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  pages           Page[]
  hotspots        Hotspot[]

  @@unique([publicationId, spreadIdx])
  @@map("spreads")
}

model Page {
  id              Int       @id @default(autoincrement())
  publicationId   Int       @map("publication_id")
  pageNumber      Int       @map("page_number")
  spreadId        Int?      @map("spread_id")
  pageIdRemote    Int?      @map("page_id_remote")
  imageAt2400     String?   @map("image_at2400")
  imageAt2000     String?   @map("image_at2000")
  imageAt1600     String?   @map("image_at1600")
  imageAt1200     String?   @map("image_at1200")
  imageAt1000     String?   @map("image_at1000")
  imageAt800      String?   @map("image_at800")
  imageAt600      String?   @map("image_at600")
  imageAt200      String?   @map("image_at200")

  publication     Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  spread          Spread?     @relation(fields: [spreadId], references: [id], onDelete: SetNull)

  @@unique([publicationId, pageNumber])
  @@map("pages")
}

model Hotspot {
  id                Int       @id @default(autoincrement())
  publicationId     Int       @map("publication_id")
  spreadId          Int       @map("spread_id")
  hotspotIdRemote   Int       @map("hotspot_id_remote")
  type              String?
  title             String?
  pageRange         String?   @map("page_range")
  clickable         Int?
  positionLeft      Float?    @map("position_left")
  positionTop       Float?    @map("position_top")
  positionWidth     Float?    @map("position_width")
  positionHeight    Float?    @map("position_height")
  positionIconLeft  Float?    @map("position_icon_left")
  positionIconTop   Float?    @map("position_icon_top")
  raw               String?

  publication     Publication     @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  spread          Spread          @relation(fields: [spreadId], references: [id], onDelete: Cascade)
  offerings       ProductOffering[]

  @@unique([publicationId, hotspotIdRemote])
  @@map("hotspots")
}

model ProductOffering {
  id                  Int       @id @default(autoincrement())
  productId           Int       @map("product_id")
  publicationId       Int       @map("publication_id")
  hotspotId           Int?      @map("hotspot_id")
  productIdRemote     Int       @map("product_id_remote")
  title               String?
  description         String?
  brand               String?
  price               String?
  priceNumeric        Float?    @map("price_numeric")
  discountedPrice     String?   @map("discounted_price")
  discountedPriceNumeric Float? @map("discounted_price_numeric")
  currency            String    @default("EUR")
  productType         String?   @map("product_type")
  webshopIdentifier   String?   @map("webshop_identifier")
  webshopUrl          String?   @map("webshop_url")
  spread              String?
  pageRange           String?   @map("page_range")
  raw                 String?

  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  publication   Publication   @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  hotspot       Hotspot?      @relation(fields: [hotspotId], references: [id], onDelete: SetNull)
  photos        ProductPhoto[]
  labels        ProductLabel[]

  @@unique([productId, publicationId, productIdRemote])
  @@map("product_offerings")
}

model ProductPhoto {
  id          Int       @id @default(autoincrement())
  offeringId  Int       @map("offering_id")
  url         String
  kind        String?
  width       Int?

  offering   ProductOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  @@unique([offeringId, url])
  @@map("product_photos")
}

model ProductLabel {
  id          Int       @id @default(autoincrement())
  offeringId  Int       @map("offering_id")
  key         String
  value       String?

  offering   ProductOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  @@unique([offeringId, key])
  @@map("product_labels")
}

model ProductTitle {
  id                Int       @id @default(autoincrement())
  productId         Int       @map("product_id")
  title             String
  firstSeenPubId    Int       @map("first_seen_pub_id")
  lastSeenPubId     Int       @map("last_seen_pub_id")
  firstSeenAt       String    @map("first_seen_at")
  lastSeenAt        String    @map("last_seen_at")

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, title])
  @@map("product_titles")
}

model ProductDescription {
  id                Int       @id @default(autoincrement())
  productId         Int       @map("product_id")
  description       String
  firstSeenPubId    Int       @map("first_seen_pub_id")
  lastSeenPubId     Int       @map("last_seen_pub_id")
  firstSeenAt       String    @map("first_seen_at")
  lastSeenAt        String    @map("last_seen_at")

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, description])
  @@map("product_descriptions")
}

model ProductBrand {
  id                Int       @id @default(autoincrement())
  productId         Int       @map("product_id")
  brand             String
  firstSeenPubId    Int       @map("first_seen_pub_id")
  lastSeenPubId     Int       @map("last_seen_pub_id")
  firstSeenAt       String    @map("first_seen_at")
  lastSeenAt        String    @map("last_seen_at")

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, brand])
  @@map("product_brands")
}
